# ===============================
# Celio E-commerce Environment Variables
# ===============================
# Copy this file to .env and fill in your real values.

# -------------------------------
# Database (Neon - PostgreSQL)
# -------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
PGDATABASE=your_database_name
PGHOST=your-neon-host.neon.tech
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password

# -------------------------------
# Application Settings
# -------------------------------
NODE_ENV=production
PORT=5000
SESSION_SECRET=replace-with-a-long-random-string

# -------------------------------
# Email (Resend)
# -------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# -------------------------------
# Stripe
# -------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------
# PayPal (optional)
# -------------------------------
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_MODE=sandbox

# -------------------------------
# Replicate (Virtual Try-On AI)
# -------------------------------
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------
# Object Storage (optional)
# -------------------------------
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=

# -------------------------------
# Google Cloud Storage (optional)
# -------------------------------
# GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
# GOOGLE_CLOUD_STORAGE_BUCKET=your_storage_bucket_name
# GOOGLE_CLOUD_KEY_FILE=./config/gcp-service-account.json

# -------------------------------
# Security / CORS
# -------------------------------
CORS_ORIGIN=http://localhost:5000,https://yourdomain.com

# -------------------------------
# Images Hosting
# -------------------------------
IMAGE_BASE_URL=https://yourcdn.example.com/

# -------------------------------
# API Endpoints
# -------------------------------
VITE_API_BASE_URL=http://localhost:5000/api
# Production:
# VITE_API_BASE_URL=https://yourdomain.com/api
